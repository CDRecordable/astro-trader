# Astro Trader Insights - Environment Variables

# PostgreSQL connection string (Neon) — OPTIONAL.
# If set, scanned companies/crypto are cached here (faster, persistent).
# If omitted, the app runs in "no-cache" mode: every analysis is fetched live
# and nothing is persisted server-side (your watchlist, portfolio and saved AI
# analyses still persist locally in user-data/). Add an LLM key in Settings to
# enable the qualitative AI analysis.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Optional API keys (LLM providers, CoinMarketCal) are configured in-app under
# Settings and stored locally in user-data/settings.json — never here.
